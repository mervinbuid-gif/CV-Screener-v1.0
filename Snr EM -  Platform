    "distributed_systems_cloud": { "score": 0, "max": 10, "evidence": "..." },
    "cloud_infrastructure": { "score": 0, "max": 10, "evidence": "..." },
    "architecture_governance": { "score": 0, "max": 10, "evidence": "..." },
    "stakeholder_management": { "score": 0, "max": 10, "evidence": "..." },
    "platform_domains": { "score": 0, "max": 5, "evidence": "..." },
    "fullstack_frontend": { "score": 0, "max": 5, "evidence": "..." },
    "cicd_devops": { "score": 0, "max": 5, "evidence": "..." },
    "startup_experience": { "score": 0, "max": 5, "evidence": "..." },
    "multi_tenant_service_mesh": { "score": 0, "max": 3, "evidence": "..." },
    "asean_travel_fintech": { "score": 0, "max": 4, "evidence": "..." },
